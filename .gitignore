# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# research artifacts & tooling
# Block one-off research scripts but allow active build/validation scripts.
scripts/*
!scripts/validate/
!scripts/validate/**
!scripts/parse-area-band-d.py
!scripts/sync-band-d.mjs
!scripts/generate-coverage-stats.mjs
!scripts/generate-provenance.mjs
!scripts/data-audit-log.mjs
!scripts/requirements.txt
!scripts/fetch-private-data.mjs
scripts/validate/reports/*.json
council_pdfs/
pdf_downloads/
pdf_extracts/
temp_images/
.gstack/

# Private data — see /DATA-ACCESS-POLICY.md.
# The entire src/data/councils/ folder is fetched at build time from the
# private civaccount-data repo using CIVACCOUNT_DATA_TOKEN (see
# scripts/fetch-private-data.mjs). Nothing at that path is ever tracked here.
# Fixtures at src/data/councils-fixtures/ remain tracked and serve as the
# fallback when the token is absent or the fetch fails.
/src/data/councils/
/scripts/data-scripts/
